{
  "version": "1.0",
  "project": "qoder-java-review-governance",
  "description": "Harness Engineering 配置 - 代码审查执行器",
  "rule_catalog": "harness/rules/catalog",
  "schema": "harness/rules/review-rule-schema.yaml",
  "cr_flows": {
    "review-diff": {
      "description": "审查 git diff",
      "scope": "review-diff",
      "default_objective": null,
      "include_governance": false,
      "limit": 8
    },
    "review-file": {
      "description": "审查单个文件",
      "scope": "review-file",
      "default_objective": null,
      "include_governance": false,
      "limit": 8
    },
    "review-module": {
      "description": "审查整个 module 或 package",
      "scope": "review-module",
      "default_objective": null,
      "include_governance": false,
      "limit": 12
    },
    "review-architecture": {
      "description": "架构审查",
      "scope": "review-architecture",
      "default_objective": "architecture",
      "include_governance": true,
      "limit": 15
    }
  },
  "execution": {
    "rule_selection_strategy": "targeted",
    "minimum_score": 4,
    "score_boost_for_semantic": 1,
    "targeted_match_priority": true,
    "三层召回机制": {
      "第一层_精确匹配": "scope + objective + path/module 命中",
      "第二层_语义相关": "objective 或 path keyword 匹配",
      "第三层_兜底策略": "semantic-review 默认加载规则"
    }
  },
  "skills": {
    "root": ".qoder/skills",
    "mapping": {
      "persistence": "java-review-persistence",
      "controller-service": "java-review-mvc-controller-service",
      "exception": "java-review-exception-semantics",
      "spring-layering": "java-review-spring-layering",
      "sofa-boundary": "java-review-sofa-boundary",
      "domain-boundary": "java-review-domain-boundary",
      "architecture": "java-review-architecture"
    }
  },
  "output": {
    "format": "structured",
    "separate_semantic_and_deterministic": true,
    "include_rule_id": true,
    "include_severity": true,
    "include_checklist": true
  }
}
